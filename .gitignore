# Source bundles / handoffs — not part of the deployed site
_extracted/
*.zip

# Local archive of retired files (handoffs, old SPA, done planning docs).
# Tracked items moved here are git-rm'd from the repo; history still has them.
_archive/

# Claude Code tooling installs — local, not project code
.agents/
.claude/skills/
skills-lock.json
.claude/scheduled_tasks.lock

# Per-agent coordination-watch snapshots (local diff state, never shared)
.coordination-watch/

# The agentic AEO pipeline is a separate deployable (its own repo) — never serve it as static
pipeline/

# Local env / secrets — never commit
.env
.env.*
!.env.example

# OS / editor cruft
.DS_Store
Thumbs.db
*.log
node_modules/

# Local verification artifacts (Playwright)
_verify*.png
_verify.mjs
package-lock.json
# …but web/ is a real Next.js app deployed via `npm ci`, which REQUIRES its
# lockfile committed (without it the DO build fails: "package-lock.json does
# not exist"). Keep this exception.
!web/package-lock.json

# Stray pipeline run artifacts if the CLI is ever run from the site root
out/

# Transient DO deploy scratch (never commit tokens/specs)
_do_token.txt
_do_app.json
_do_resp.json

# session temp / local artifacts
_codex_consult.md
_check-*.png
_last_report.json
_scan_e2e.mjs
_stripe_*.py
_stripe_*.json

# Stray downloads / binaries — never commit (e.g. comet_installer_latest.exe)
*.exe

# Throwaway responsive/audit screenshot runs
artifacts/

# Ad-hoc QA gate harness output
_qa_gate*
