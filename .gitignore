# Source bundles / handoffs — not part of the deployed site
_extracted/
*.zip

# The agentic AEO pipeline is a separate deployable (its own repo) — never serve it as static
pipeline/

# Local env / secrets — never commit
.env
.env.*
!.env.example

# OS / editor cruft
.DS_Store
Thumbs.db
*.log
node_modules/

# Local verification artifacts (Playwright)
_verify*.png
_verify.mjs
package-lock.json

# Stray pipeline run artifacts if the CLI is ever run from the site root
out/

# Transient DO deploy scratch (never commit tokens/specs)
_do_token.txt
_do_app.json
_do_resp.json

# session temp / local artifacts
_codex_consult.md
_check-*.png
_last_report.json
_scan_e2e.mjs
_stripe_*.py
_stripe_*.json

# Stray downloads / binaries — never commit (e.g. comet_installer_latest.exe)
*.exe

# Throwaway responsive/audit screenshot runs
artifacts/

# Ad-hoc QA gate harness output
_qa_gate*
