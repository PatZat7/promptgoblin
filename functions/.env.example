# Prompt Goblin scan functions — environment.
# Copy to .env for local notes; NEVER commit a real key.
# In production, set this on the DO Functions namespace (see README "Deploy").

# Tier-2 only. Perplexity uses an OpenAI-compatible API (base https://api.perplexity.ai)
# and returns native citations. Without this key, Tier-2 degrades to an honest
# "configure key" message and Tier-1 still runs fully.
PERPLEXITY_API_KEY=

# Tier-1 WAF bypass (optional). When set, WAF-blocked scans retry via Scrapfly's
# residential-proxy ASP mode instead of returning blocked_by_waf immediately.
# Free tier: 1k credits/mo (enough for testing). Get a key at scrapfly.io.
SCRAPFLY_KEY=
