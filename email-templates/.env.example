# Prompt Goblin scan-report mailer — copy to .env and fill in.
# .env is gitignored (root .gitignore: .env / .env.*). NEVER commit a real key.

# Which service to send through: "resend" (default) or "postmark".
EMAIL_PROVIDER=resend

# --- Resend (https://resend.com) ---
# Create an API key, then verify the sending domain (promptgoblin.io) so DKIM/SPF
# pass — otherwise mail lands in spam or is rejected.
RESEND_API_KEY=

# --- Postmark (https://postmarkapp.com) — only if EMAIL_PROVIDER=postmark ---
# POSTMARK_API_TOKEN=

# Sender + reply-to. The from-domain MUST be the one you verified above.
MAIL_FROM=Prompt Goblin <goblins@promptgoblin.io>
# MAIL_REPLY_TO=goblins@promptgoblin.io
