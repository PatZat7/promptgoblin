# web/.env.example — copy to .env.local and fill in real values.
# .env.local is gitignored — NEVER commit .env.local or any file with real keys.

# ── Supabase (publishable — safe to expose to the browser) ───────────────────
# These map to SUPABASE_PROJECT_URL and the anon/publishable key in your
# Supabase project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Service role key (SERVER-SIDE ONLY — never NEXT_PUBLIC_) ─────────────────
# Used only in web/lib/supabase/signed-urls.ts (imported with "server-only").
# Found in Supabase Settings → API → service_role key.
# WARNING: this key bypasses RLS — never expose it to the browser or commit it.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── PostHog (publishable — already in use) ───────────────────────────────────
# NEXT_PUBLIC_POSTHOG_KEY=phc_...
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── e2e dashboard tests (DEV/PREVIEW ONLY — never CI, never production) ───────
# web/e2e/dashboard.spec.ts fakes auth with a seeded session cookie so tests
# never hit a real mailbox. The whole dashboard spec SKIPS (not fails) unless
# NEXT_PUBLIC_SUPABASE_URL is set; the authed cases additionally skip unless
# TEST_SESSION_COOKIE is set. Run against a local `next start`/`next dev` on :3010.
#
# TEST_SESSION_COOKIE: the seeded fixture user's Supabase session cookie(s), as
#   `name=value` (";"-separate multiple; Supabase chunks large tokens into
#   `sb-<ref>-auth-token.0`, `.1`, …). Mint it from a service-role JWT for a
#   throwaway fixture user against a local/preview Supabase — NEVER a real user.
# TEST_SESSION_COOKIE=sb-your-ref-auth-token.0=...; sb-your-ref-auth-token.1=...
#
# TEST_WAF_RUN_ID: (optional) id of a seeded WAF/unreadable run, so
#   `blind_spot_run_not_zero` can assert the blind-spot flag (else it skips).
# TEST_WAF_RUN_ID=
#
# DASHBOARD_BASE_URL: override the base the e2e hits (default http://localhost:3010).
# DASHBOARD_BASE_URL=http://localhost:3010
